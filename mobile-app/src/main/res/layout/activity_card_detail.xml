                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_markets" />
            <TextView
                android:id="@+id/detailMarkets"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_partners" />
            <TextView
                android:id="@+id/detailPartners"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/section_opportunity" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_opportunities" />
            <TextView
                android:id="@+id/detailOpportunities"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_investment" />
            <TextView
                android:id="@+id/detailInvestment"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_timing" />
            <TextView
                android:id="@+id/detailTiming"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
