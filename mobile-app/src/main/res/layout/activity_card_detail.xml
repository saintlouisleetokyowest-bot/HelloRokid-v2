                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_address" />
            <TextView
                android:id="@+id/detailAddress"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_website" />
            <TextView
                android:id="@+id/detailWebsite"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
                style="@style/TextAppearance.HelloRokid.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/section_company_intel" />

            <TextView
                style="@style/TextAppearance.HelloRokid.DetailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_industry" />
            <TextView
                android:id="@+id/detailIndustry"
                style="@style/TextAppearance.HelloRokid.DetailValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <TextView
